#taking user input numbers, giving sorted even or odd numbers.

num=input("enter a list of numbers= ").split()
even_num=[]
odd_num=[]
for n in num:
    m=int(n)
    if m%2==0:
        even_num.append(m)
    else:
        odd_num.append(m)

print(f"{even_num} = even")
print(f"{odd_num} = odd")

